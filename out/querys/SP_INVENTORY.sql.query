11	SELECT QUANTITY INTO v_qty FROM INVENTORY WHERE PRODUCT_ID = p_product_id AND WAREHOUSE_ID = 1	CheckStock
28	SELECT PRODUCT_NAME INTO v_product_name FROM PRODUCTS WHERE PRODUCT_ID = p_product_id	UpdateStock
33	UPDATE INVENTORY SET QUANTITY = QUANTITY + p_delta, UPDATED_AT = SYSDATE WHERE PRODUCT_ID = p_product_id	UpdateStock
48	INSERT INTO INVENTORY (INV_ID, PRODUCT_ID, WAREHOUSE_ID, QUANTITY, UPDATED_AT) VALUES (SEQ_INV.NEXTVAL, p_product_id, p_warehouse_id, p_quantity, SYSDATE)	AddInventory
