<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="CRUDExplorer.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="CRUDExplorer - SQL CRUD Analysis Tool"
        Width="1200" Height="800">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="フォルダを開く(_O)" Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="終了(_X)" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="解析(_A)">
                <MenuItem Header="CRUD解析実行(_C)" Command="{Binding AnalyzeCrudCommand}" />
                <MenuItem Header="テーブル定義読み込み(_T)" Command="{Binding LoadTableDefCommand}" />
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="テーブルCRUD(_T)" Command="{Binding ShowTableCrudCommand}" />
                <MenuItem Header="カラムCRUD(_C)" Command="{Binding ShowColumnCrudCommand}" />
                <Separator />
                <MenuItem Header="フィルタ(_F)" Command="{Binding ShowFilterCommand}" />
            </MenuItem>
            <MenuItem Header="設定(_S)">
                <MenuItem Header="設定(_S)" Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)" Command="{Binding ShowVersionCommand}" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="5,3">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
        </Border>

        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#F8F8F8" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="10,5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="フォルダ選択" Command="{Binding OpenFolderCommand}" />
                    <TextBlock Text="ソースパス:" VerticalAlignment="Center" Margin="10,0,0,0" />
                    <TextBox Text="{Binding SourcePath}" IsReadOnly="True" MinWidth="400" VerticalAlignment="Center" />
                    <Button Content="CRUD解析" Command="{Binding AnalyzeCrudCommand}" />
                    <Button Content="テーブル定義" Command="{Binding LoadTableDefCommand}" />
                </StackPanel>
            </Border>

            <!-- Split View: DataGrid and ListBox -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- DataGrid Area (CRUD Matrix) -->
                <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- DataGrid Header -->
                        <Border Grid.Row="0" Background="#E8E8E8" Padding="5">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="CRUDマトリクス" FontWeight="Bold" VerticalAlignment="Center" />
                                <ComboBox SelectedIndex="{Binding CrudViewType}" MinWidth="150">
                                    <ComboBoxItem Content="テーブルCRUD" />
                                    <ComboBoxItem Content="カラムCRUD" />
                                </ComboBox>
                                <TextBox Watermark="フィルタ..." Text="{Binding FilterText}" MinWidth="200" />
                            </StackPanel>
                        </Border>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding CrudMatrixData}"
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  BorderThickness="0"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True">
                            <!-- Columns will be generated dynamically based on data -->
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- GridSplitter -->
                <GridSplitter Grid.Column="1" Background="#D0D0D0" ResizeDirection="Columns" />

                <!-- ListBox Area (CRUD List) -->
                <Border Grid.Column="2" BorderBrush="#D0D0D0" BorderThickness="1" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- ListBox Header -->
                        <Border Grid.Row="0" Background="#E8E8E8" Padding="5">
                            <TextBlock Text="CRUD一覧" FontWeight="Bold" />
                        </Border>

                        <!-- ListBox -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding CrudListData}"
                                 SelectedItem="{Binding SelectedCrudItem}"
                                 DoubleTapped="OnListBoxDoubleTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
