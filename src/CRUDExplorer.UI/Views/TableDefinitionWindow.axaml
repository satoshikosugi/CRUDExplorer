<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1008" d:DesignHeight="550"
        x:Class="CRUDExplorer.UI.Views.TableDefinitionWindow"
        x:DataType="vm:TableDefinitionViewModel"
        Title="テーブル定義" Width="1008" Height="550"
        CanResize="True">

  <DockPanel>
    <!-- Bottom: 閉じるボタン -->
    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="0,1,0,0" Padding="6">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="閉じる(_C)" Width="94" Command="{Binding CloseCommand}" />
      </StackPanel>
    </Border>

    <!-- Main: 左右SplitView -->
    <Grid ColumnDefinitions="306,4,*">

      <!-- ─── 左: テーブル一覧 ─── -->
      <Grid Grid.Column="0" RowDefinitions="Auto,*">
        <!-- フィルタバー -->
        <Border Grid.Row="0" Padding="4">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBox Grid.Column="0" Text="{Binding TableFilter}"
                     Watermark="テーブル名フィルタ" Margin="0,0,4,0"
                     KeyDown="OnFilterKeyDown" />
            <Button Grid.Column="1" Content="フィルタ適用" Width="80"
                    Command="{Binding ApplyFilterCommand}" Margin="0,0,4,0" />
            <Button Grid.Column="2" Content="フィルタクリア" Width="80"
                    Command="{Binding ClearFilterCommand}" />
          </Grid>
        </Border>

        <!-- テーブルリスト -->
        <DataGrid Grid.Row="1" Name="TableListGrid"
                  ItemsSource="{Binding TableListItems}"
                  SelectedItem="{Binding SelectedTableItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column">
          <DataGrid.Columns>
            <DataGridTextColumn Header="テーブル名" Binding="{Binding TableName}" Width="170" />
            <DataGridTextColumn Header="エンティティ名" Binding="{Binding LogicalName}" Width="*" />
          </DataGrid.Columns>
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="CRUDサーチ">
                <MenuItem Header="このテーブルにアクセスしている処理"
                          Command="{Binding SearchTableAccessCommand}" />
                <MenuItem Header="このカラムにアクセスしている処理"
                          Command="{Binding SearchColumnAccessCommand}"
                          IsEnabled="False" />
              </MenuItem>
            </ContextMenu>
          </DataGrid.ContextMenu>
        </DataGrid>
      </Grid>

      <!-- スプリッター -->
      <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

      <!-- ─── 右: カラム定義 ─── -->
      <DataGrid Grid.Column="2" Name="ColumnDefGrid"
                ItemsSource="{Binding Columns}"
                SelectedItem="{Binding SelectedColumnItem}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="All"
                SelectionMode="Single"
                CanUserSortColumns="True"
                HeadersVisibility="Column">
        <DataGrid.Columns>
          <DataGridTextColumn Header="No" Binding="{Binding Sequence}" Width="40" />
          <DataGridTextColumn Header="カラム名" Binding="{Binding PhysicalName}" Width="200" />
          <DataGridTextColumn Header="属性名" Binding="{Binding ColumnName}" Width="170" />
          <DataGridTextColumn Header="PK" Binding="{Binding PkDisplay}" Width="48" />
          <DataGridTextColumn Header="FK" Binding="{Binding FkDisplay}" Width="45" />
          <DataGridTextColumn Header="必須" Binding="{Binding RequiredDisplay}" Width="50" />
          <DataGridTextColumn Header="データ型" Binding="{Binding DataType}" Width="100" />
          <DataGridTextColumn Header="桁数" Binding="{Binding Digits}" Width="60" />
          <DataGridTextColumn Header="精度" Binding="{Binding Accuracy}" Width="60" />
        </DataGrid.Columns>
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="CRUDサーチ">
              <MenuItem Header="このテーブルにアクセスしている処理"
                        Command="{Binding SearchTableAccessCommand}" />
              <MenuItem Header="このカラムにアクセスしている処理"
                        Command="{Binding SearchColumnAccessCommand}" />
            </MenuItem>
          </ContextMenu>
        </DataGrid.ContextMenu>
      </DataGrid>
    </Grid>
  </DockPanel>
</Window>
