119	UPDATE ORDERS SET STATUS = 'CONFIRMED', UPDATED_AT = SYSDATE WHERE STATUS = 'PENDING' AND ORDER_ID IN ( SELECT py.ORDER_ID FROM PAYMENTS py WHERE py.PAYMENT_STATUS = 'COMPLETED' AND py.PAYMENT_DATE IS NOT NULL )	SP_BATCH_PROCESS.AutoTransitionOrderStatus
