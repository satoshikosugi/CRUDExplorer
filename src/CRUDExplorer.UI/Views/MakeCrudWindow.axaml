<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="CRUDExplorer.UI.Views.MakeCrudWindow"
        x:DataType="vm:MakeCrudViewModel"
        Title="CRUD解析実行" Width="700" Height="600"
        CanResize="True">

  <DockPanel Margin="12" Background="{StaticResource AppBackgroundBrush}">
    <!-- Bottom Buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
      <Button Content="▶ 解析実行(_E)" Width="120" Command="{Binding ExecuteAnalysisCommand}" />
      <Button Content="閉じる(_C)" Width="100" Command="{Binding CloseCommand}" />
    </StackPanel>

    <!-- Main Content -->
    <ScrollViewer>
      <StackPanel Spacing="10">
        <!-- Source Folder Selection -->
        <TextBlock Text="ソースフォルダ:" FontWeight="Bold" />
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
          <TextBox Grid.Column="0" Text="{Binding SourcePath}" IsReadOnly="True" />
          <Button Grid.Column="1" Content="参照..." Width="80" Margin="5,0,0,0" Command="{Binding SelectSourceFolderCommand}" />
        </Grid>

        <!-- Destination Folder Selection -->
        <TextBlock Text="出力先フォルダ:" FontWeight="Bold" />
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
          <TextBox Grid.Column="0" Text="{Binding DestPath}" IsReadOnly="True" />
          <Button Grid.Column="1" Content="参照..." Width="80" Margin="5,0,0,0" Command="{Binding SelectDestFolderCommand}" />
        </Grid>

        <!-- Processing Steps -->
        <TextBlock Text="処理ステップ:" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryBrush}" />
        <Border Background="White" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
          <StackPanel Spacing="6">
            <CheckBox Content="全ステップ実行" IsChecked="{Binding ProcessAll}" FontWeight="SemiBold" />
            <Separator />
            <CheckBox Content="Step 0: ソースコピー" IsChecked="{Binding Step0_SourceCopy}" IsEnabled="{Binding !ProcessAll}" />
            <CheckBox Content="Step 1: 動的SQL抽出" IsChecked="{Binding Step1_ExtractDynamicSql}" IsEnabled="{Binding !ProcessAll}" />
            <CheckBox Content="Step 2: クエリ抽出" IsChecked="{Binding Step2_ExtractQuery}" IsEnabled="{Binding !ProcessAll}" />
            <CheckBox Content="Step 3: CRUD解析" IsChecked="{Binding Step3_AnalyzeCrud}" IsEnabled="{Binding !ProcessAll}" />
            <CheckBox Content="Step 4: CRUDマトリクス生成" IsChecked="{Binding Step4_GenerateMatrix}" IsEnabled="{Binding !ProcessAll}" />
          </StackPanel>
        </Border>

        <!-- Options -->
        <TextBlock Text="オプション:" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryBrush}" />
        <Border Background="White" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
          <StackPanel Spacing="6">
            <CheckBox Content="VIEW間接参照を反映する" IsChecked="{Binding ReflectViewIndirect}" />
            <CheckBox Content="参照条件を確認する" IsChecked="{Binding CheckReferenceCondition}" />
          </StackPanel>
        </Border>

        <!-- Analysis Log -->
        <TextBlock Text="解析ログ:" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryBrush}" />
        <TextBox Text="{Binding AnalysisLog}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Height="200"
                 Background="#FAFAFA"
                 FontFamily="Consolas,Courier New,monospace"
                 FontSize="12"
                 BorderBrush="{StaticResource AppBorderBrush}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
