<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="CRUDExplorer.UI.Views.GrepWindow"
        x:DataType="vm:GrepViewModel"
        Title="Grep検索" Width="900" Height="700"
        CanResize="True">

  <DockPanel Margin="10">
    <!-- Bottom Buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
      <Button Content="エディタで開く(_O)" Width="120" Command="{Binding OpenInEditorCommand}" />
      <Button Content="クエリ解析(_A)" Width="100" Command="{Binding AnalyzeQueryCommand}" ToolTip.Tip="選択したクエリを解析ウィンドウで開く" />
      <Button Content="クエリ解析(新規)" Width="120" Command="{Binding AnalyzeQueryNewCommand}" ToolTip.Tip="新しいウィンドウでクエリを解析" />
      <Button Content="閉じる(_C)" Width="100" Command="{Binding CloseCommand}" />
    </StackPanel>

    <!-- Main Content -->
    <Grid RowDefinitions="Auto,*">
      <!-- Search Criteria Panel -->
      <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
        <StackPanel Spacing="10">
        <TextBlock Text="Grep検索条件" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AppPrimaryBrush}" />
          <Separator />

          <!-- Search Pattern -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="検索パターン:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Grid.Column="1" Text="{Binding SearchPattern}" Watermark="検索する文字列または正規表現" />
            <Button Grid.Column="2" Content="検索(_S)" Width="100" Margin="10,0,0,0" Command="{Binding SearchCommand}" />
          </Grid>

          <!-- Search Options -->
          <StackPanel Orientation="Horizontal" Spacing="20">
            <CheckBox Content="正規表現を使用" IsChecked="{Binding UseRegex}" />
            <CheckBox Content="大文字小文字を区別" IsChecked="{Binding CaseSensitive}" />
            <CheckBox Content="単語全体を検索" IsChecked="{Binding WholeWord}" />
          </StackPanel>

          <!-- Search Scope -->
          <TextBlock Text="検索範囲:" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="15">
            <RadioButton Content="現在のファイル" IsChecked="{Binding SearchCurrentFile}" />
            <RadioButton Content="現在のプログラム" IsChecked="{Binding SearchCurrentProgram}" />
            <RadioButton Content="全ファイル" IsChecked="{Binding SearchAllFiles}" />
          </StackPanel>

          <!-- File Filter -->
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="ファイルフィルタ:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Grid.Column="1" Text="{Binding FileFilter}" Watermark="例: *.cs, *.vb" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Search Results -->
      <Border Grid.Row="1" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="5">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top"
                     Text="{Binding ResultSummary}"
                     FontWeight="Bold"
                     Margin="5,0,5,5" />
          <ListBox ItemsSource="{Binding SearchResults}"
                   SelectedItem="{Binding SelectedResult}"
                   DoubleTapped="OnResultDoubleClicked">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="2">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding FileName}" FontWeight="SemiBold" Margin="0,0,10,0" />
                    <TextBlock Grid.Column="1" Text="{Binding FilePath}" FontSize="11" Foreground="{StaticResource AppSecondaryTextBrush}" />
                    <TextBlock Grid.Column="2" Text="{Binding MatchCount, StringFormat='({0}件)'}" FontSize="11" Foreground="Blue" />
                  </Grid>
                  <TextBlock Text="{Binding PreviewText}"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="11"
                             Margin="20,0,0,0" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
