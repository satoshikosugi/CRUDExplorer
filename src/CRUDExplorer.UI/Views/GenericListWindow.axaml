<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="CRUDExplorer.UI.Views.GenericListWindow"
        x:DataType="vm:GenericListViewModel"
        Title="{Binding WindowTitle}" Width="700" Height="600"
        CanResize="True">

  <DockPanel Margin="10">
    <!-- Bottom Buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
      <Button Content="選択(_S)" Width="100" Command="{Binding SelectCommand}" />
      <Button Content="閉じる(_C)" Width="100" Command="{Binding CloseCommand}" />
    </StackPanel>

    <!-- Filter Panel -->
    <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="フィルタ:" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox Grid.Column="1" Text="{Binding FilterText}" Watermark="部分一致で絞り込み" />
        <Button Grid.Column="2" Content="クリア" Command="{Binding ClearFilterCommand}" Margin="10,0,0,0" />
      </Grid>
    </Border>

    <!-- List View -->
    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="5">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ItemCountText}"
                   FontWeight="Bold"
                   Margin="5,0,5,5" />
        <ListBox ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 SelectionMode="{Binding SelectionMode}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayText}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </DockPanel>
</Window>
