159	UPDATE ORDERS SET STATUS = 'CANCELLED', UPDATED_AT = SYSDATE WHERE STATUS = 'PENDING' AND ORDER_DATE < SYSDATE - 7 AND ORDER_ID NOT IN ( SELECT py.ORDER_ID FROM PAYMENTS py WHERE py.PAYMENT_STATUS IN ( 'COMPLETED', 'PROCESSING' ) )	SP_BATCH_PROCESS.AutoTransitionOrderStatus
