<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="CRUDExplorer.UI.Views.AnalyzeQueryWindow"
        x:DataType="vm:AnalyzeQueryViewModel"
        Title="{Binding WindowTitle}" Width="1200" Height="800"
        CanResize="True">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+F" Command="{Binding OpenSearchCommand}" />
    <KeyBinding Gesture="F3" Command="{Binding SearchNextCommand}" />
    <KeyBinding Gesture="Shift+F3" Command="{Binding SearchPreviousCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding CloseWindowCommand}" />
  </Window.KeyBindings>

  <DockPanel>
    <!-- ヘッダーバー (Panel1相当) -->
    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="5,3">
      <Grid ColumnDefinitions="Auto,250,Auto,170,Auto,50,Auto,150,Auto,50,*,Auto">
        <TextBlock Grid.Column="0" Text="ソース切替え" VerticalAlignment="Center" Margin="0,0,5,0" />
        <ComboBox Grid.Column="1" ItemsSource="{Binding Queries}" SelectedItem="{Binding SelectedQuery}" />

        <TextBlock Grid.Column="2" Text="ファイル名" VerticalAlignment="Center" Margin="10,0,5,0" />
        <TextBox Grid.Column="3" Text="{Binding FileName}" IsReadOnly="True" />

        <TextBlock Grid.Column="4" Text="行番号" VerticalAlignment="Center" Margin="10,0,5,0" />
        <TextBox Grid.Column="5" Text="{Binding LineNumber}" IsReadOnly="True" HorizontalContentAlignment="Right" />

        <TextBlock Grid.Column="6" Text="テーブル名" VerticalAlignment="Center" Margin="10,0,5,0" />
        <TextBox Grid.Column="7" Text="{Binding TableName}" IsReadOnly="True" />

        <TextBlock Grid.Column="8" Text="代替" VerticalAlignment="Center" Margin="10,0,5,0" />
        <TextBox Grid.Column="9" Text="{Binding AltName}" IsReadOnly="True" />

        <StackPanel Grid.Column="11" Orientation="Horizontal" Spacing="5">
          <Button Content="閉じる(C)" Command="{Binding CloseWindowCommand}" />
          <Button Content="エディタ起動(E)" Command="{Binding LaunchEditorCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ツールバー1行目: SQL解析/論理名変換/文字列抽出/自動解析/F12 -->
    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="3,3">
      <StackPanel Orientation="Horizontal" Spacing="3">
        <Button Content="SQL解析(A)" Command="{Binding QuickAnalyzeCommand}" />
        <Button Content="論理名変換" Command="{Binding ConvertLogicalNameCommand}" />
        <Button Content="文字列抽出" Command="{Binding ExtractStringsCommand}" />
        <Separator Width="1" Background="Gray" Margin="3,0" />
        <CheckBox Content="自動解析" IsChecked="{Binding IsAutoAnalyze}" VerticalAlignment="Center" />
        <TextBlock Text="[F12]" VerticalAlignment="Center" Margin="5,0" Foreground="Gray" />
      </StackPanel>
    </Border>

    <!-- ツールバー2行目: Viewを展開/整形/テーブル定義/前/検索/次 -->
    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="3,3">
      <StackPanel Orientation="Horizontal" Spacing="3">
        <Button Content="Viewを展開" Command="{Binding ExpandViewCommand}" />
        <Button Content="整形(E)" Command="{Binding FormatSqlCommand}" />
        <Button Content="テーブル定義(T)" Command="{Binding ShowTableDefinitionCommand}" />
        <Separator Width="1" Background="Gray" Margin="3,0" />
        <Button Content="前" Command="{Binding SearchPreviousCommand}" Width="30" />
        <Button Content="検索(F8)" Command="{Binding OpenSearchCommand}" />
        <Button Content="次" Command="{Binding SearchNextCommand}" Width="30" />
      </StackPanel>
    </Border>

    <!-- ハイライトバー -->
    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="3,3">
      <Grid ColumnDefinitions="Auto,*,*,*">
        <TextBlock Grid.Column="0" Text="ハイライト" VerticalAlignment="Center" Margin="0,0,5,0" />
        <TextBox Grid.Column="1" Text="{Binding HighlightText1}" Background="#FFC0C0" Margin="0,0,5,0" />
        <TextBox Grid.Column="2" Text="{Binding HighlightText2}" Background="#80FFFF" Margin="0,0,5,0" />
        <TextBox Grid.Column="3" Text="{Binding HighlightText3}" Background="#FFFF80" />
      </Grid>
    </Border>

    <!-- ガイドバー (Panel11/txtGuide相当) -->
    <Border DockPanel.Dock="Bottom" Height="22" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <TextBox x:Name="GuideBar"
               Text="{Binding GuideText}"
               IsReadOnly="True"
               BorderThickness="0"
               FontSize="11"
               VerticalContentAlignment="Center"
               Padding="10,0" />
    </Border>

    <!-- メインエリア: 左右分割 (SplitContainer5相当) -->
    <Grid ColumnDefinitions="350,5,*">

      <!-- 左: SQLエディタ (rtbQuery相当) -->
      <ae:TextEditor Grid.Column="0"
                     x:Name="SqlEditor"
                     IsReadOnly="False"
                     FontFamily="Consolas,Courier New,monospace"
                     FontSize="12"
                     ShowLineNumbers="True"
                     HorizontalScrollBarVisibility="Disabled"
                     VerticalScrollBarVisibility="Auto">
        <ae:TextEditor.ContextMenu>
          <ContextMenu>
            <MenuItem Header="このテーブル(カラム)のCRUD一覧" Command="{Binding ShowCrudListCommand}" />
            <Separator />
            <MenuItem Header="Grep">
              <MenuItem Header="このファイルから" Command="{Binding GrepInFileCommand}" />
              <MenuItem Header="このプログラムから" Command="{Binding GrepInProgramCommand}" />
              <MenuItem Header="全てのプログラムから" Command="{Binding GrepAllCommand}" />
            </MenuItem>
            <MenuItem Header="ハイライト">
              <MenuItem Header="ハイライト１" Command="{Binding HighlightColor1Command}" />
              <MenuItem Header="ハイライト２" Command="{Binding HighlightColor2Command}" />
              <MenuItem Header="ハイライト３" Command="{Binding HighlightColor3Command}" />
              <MenuItem Header="クリア" Command="{Binding ClearHighlightCommand}" />
            </MenuItem>
            <Separator />
            <MenuItem Header="テーブル定義" Command="{Binding ShowTableDefinitionCommand}" />
          </ContextMenu>
        </ae:TextEditor.ContextMenu>
      </ae:TextEditor>

      <GridSplitter Grid.Column="1" Background="{StaticResource AppBorderBrush}" ResizeDirection="Columns" />

      <!-- 右: タブコントロール -->
      <TabControl Grid.Column="2">

        <!-- クエリ構造 [F1] タブ -->
        <TabItem Header="クエリ構造 [F1]">
          <Grid RowDefinitions="*,5,200">

            <!-- 上部: TreeView + CRUDリスト -->
            <Grid Grid.Row="0" ColumnDefinitions="*,5,*">

              <!-- TreeView (tvQuery相当) -->
              <Border Grid.Column="0" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Padding="3">
                <TreeView x:Name="QueryTreeView"
                          ItemsSource="{Binding QueryTreeData}"
                          SelectionChanged="OnTreeViewSelectionChanged"
                          KeyDown="OnTreeViewKeyDown">
                  <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                      <Setter Property="IsExpanded" Value="True" />
                    </Style>
                  </TreeView.Styles>
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                      <TextBlock Text="{Binding DisplayText}" />
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                  <TreeView.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="サブクエリを展開" Command="{Binding ExpandSubQueryCommand}" IsEnabled="{Binding HasSubQueries}" />
                      <MenuItem Header="句毎のカラムアクセス一覧" IsEnabled="{Binding IsTreeNodeSelected}">
                        <MenuItem Header="Select" Command="{Binding ShowClauseSelectCommand}" IsEnabled="{Binding HasColumnSelect}" />
                        <MenuItem Header="Where" Command="{Binding ShowClauseWhereCommand}" IsEnabled="{Binding HasColumnWhere}" />
                        <MenuItem Header="GroupBy" Command="{Binding ShowClauseGroupByCommand}" IsEnabled="{Binding HasColumnGroupBy}" />
                        <MenuItem Header="OrderBy" Command="{Binding ShowClauseOrderByCommand}" IsEnabled="{Binding HasColumnOrderBy}" />
                        <MenuItem Header="Having" Command="{Binding ShowClauseHavingCommand}" IsEnabled="{Binding HasColumnHaving}" />
                        <MenuItem Header="Insert" Command="{Binding ShowClauseInsertCommand}" IsEnabled="{Binding HasColumnInsert}" />
                        <MenuItem Header="Update" Command="{Binding ShowClauseUpdateCommand}" IsEnabled="{Binding HasColumnUpdate}" />
                        <MenuItem Header="Delete" Command="{Binding ShowClauseDeleteCommand}" IsEnabled="{Binding HasColumnDelete}" />
                        <MenuItem Header="SetCond" Command="{Binding ShowClauseSetCondCommand}" IsEnabled="{Binding HasColumnSetCond}" />
                        <MenuItem Header="全て" Command="{Binding ShowClauseInfoCommand}" />
                        <Separator />
                        <MenuItem Header="INTO句とVALUES句の対応" Command="{Binding ShowIntoValuesCommand}" IsEnabled="{Binding HasValues}" />
                        <MenuItem Header="SET句のカラムと値の対応" Command="{Binding ShowSetClauseCommand}" IsEnabled="{Binding HasSetValues}" />
                        <MenuItem Header="SELECT句の別名と式の対応" Command="{Binding ShowSelectAliasCommand}" IsEnabled="{Binding HasSelectAlias}" />
                      </MenuItem>
                    </ContextMenu>
                  </TreeView.ContextMenu>
                </TreeView>
              </Border>

              <GridSplitter Grid.Column="1" Background="{StaticResource AppBorderBrush}" ResizeDirection="Columns" />

              <!-- CRUDリスト (上下分割) -->
              <Grid Grid.Column="2" RowDefinitions="*,5,*">

                <!-- テーブルCRUDリスト -->
                <Border Grid.Row="0" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                  <DataGrid x:Name="TableCrudGrid"
                            ItemsSource="{Binding TableCrudList}"
                            AutoGenerateColumns="False"
                            CanUserSortColumns="True"
                            CanUserReorderColumns="True"
                            CanUserResizeColumns="True"
                            GridLinesVisibility="All"
                            IsReadOnly="False"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedTableCrudItem, Mode=TwoWay}"
                            SelectionChanged="OnTableCrudSelectionChanged">
                    <DataGrid.Columns>
                      <DataGridCheckBoxColumn Header="" Binding="{Binding IsChecked}" Width="30" IsReadOnly="False" />
                      <DataGridTextColumn Header="テーブル名" Binding="{Binding TableName}" Width="100" IsReadOnly="True" />
                      <DataGridTextColumn Header="エンティティ名" Binding="{Binding EntityName}" Width="100" IsReadOnly="True" />
                      <DataGridTextColumn Header="代替" Binding="{Binding AltName}" Width="50" IsReadOnly="True" />
                      <DataGridTextColumn Header="CRUD" Binding="{Binding CrudType}" Width="40" IsReadOnly="True" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="全選択" Command="{Binding CheckAllTablesCommand}" />
                        <MenuItem Header="全解除" Command="{Binding UncheckAllTablesCommand}" />
                        <MenuItem Header="テーブル定義" Command="{Binding ShowTableDefinitionFromCrudCommand}" />
                        <MenuItem Header="CRUDサーチ">
                          <MenuItem Header="このテーブルにアクセスしている処理" Command="{Binding CrudSearchTableCommand}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="コピー">
                          <MenuItem Header="選択行" Command="{Binding CopyTableSelectedRowCommand}" />
                          <MenuItem Header="チェックを付けた行" Command="{Binding CopyTableCheckedRowsCommand}" />
                          <MenuItem Header="全行" Command="{Binding CopyTableAllRowsCommand}" />
                          <Separator />
                          <MenuItem Header="テーブル名" Command="{Binding CopyTableColumnValueCommand}" CommandParameter="テーブル名" />
                          <MenuItem Header="エンティティ名" Command="{Binding CopyTableColumnValueCommand}" CommandParameter="エンティティ名" />
                          <MenuItem Header="代替" Command="{Binding CopyTableColumnValueCommand}" CommandParameter="代替" />
                          <MenuItem Header="CRUD" Command="{Binding CopyTableColumnValueCommand}" CommandParameter="CRUD" />
                        </MenuItem>
                        <MenuItem Header="クエリGrep">
                          <MenuItem Header="このファイルから">
                            <MenuItem Header="テーブル名" Command="{Binding GrepTableFromFileCommand}" CommandParameter="テーブル名" />
                            <MenuItem Header="エンティティ名" Command="{Binding GrepTableFromFileCommand}" CommandParameter="エンティティ名" />
                            <MenuItem Header="代替" Command="{Binding GrepTableFromFileCommand}" CommandParameter="代替" />
                          </MenuItem>
                          <MenuItem Header="このプログラムから">
                            <MenuItem Header="テーブル名" Command="{Binding GrepTableFromProgramCommand}" CommandParameter="テーブル名" />
                            <MenuItem Header="エンティティ名" Command="{Binding GrepTableFromProgramCommand}" CommandParameter="エンティティ名" />
                            <MenuItem Header="代替" Command="{Binding GrepTableFromProgramCommand}" CommandParameter="代替" />
                          </MenuItem>
                          <MenuItem Header="全てのプログラムから">
                            <MenuItem Header="テーブル名" Command="{Binding GrepTableFromAllCommand}" CommandParameter="テーブル名" />
                            <MenuItem Header="エンティティ名" Command="{Binding GrepTableFromAllCommand}" CommandParameter="エンティティ名" />
                            <MenuItem Header="代替" Command="{Binding GrepTableFromAllCommand}" CommandParameter="代替" />
                          </MenuItem>
                        </MenuItem>
                      </ContextMenu>
                    </DataGrid.ContextMenu>
                  </DataGrid>
                </Border>

                <GridSplitter Grid.Row="1" Background="{StaticResource AppBorderBrush}" ResizeDirection="Rows" />

                <!-- カラムCRUDリスト -->
                <Border Grid.Row="2" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                  <DataGrid x:Name="ColumnCrudGrid"
                            ItemsSource="{Binding ColumnCrudList}"
                            AutoGenerateColumns="False"
                            CanUserSortColumns="True"
                            CanUserReorderColumns="True"
                            CanUserResizeColumns="True"
                            GridLinesVisibility="All"
                            IsReadOnly="False"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedColumnCrudItem, Mode=TwoWay}">
                    <DataGrid.Columns>
                      <DataGridCheckBoxColumn Header="" Binding="{Binding IsChecked}" Width="30" IsReadOnly="False" />
                      <DataGridTextColumn Header="テーブル名" Binding="{Binding TableName}" Width="100" IsReadOnly="True" />
                      <DataGridTextColumn Header="エンティティ名" Binding="{Binding EntityName}" Width="100" IsReadOnly="True" />
                      <DataGridTextColumn Header="カラム名" Binding="{Binding ColumnName}" Width="100" IsReadOnly="True" />
                      <DataGridTextColumn Header="属性名" Binding="{Binding AttributeName}" Width="100" IsReadOnly="True" />
                      <DataGridTextColumn Header="CRUD" Binding="{Binding CrudType}" Width="40" IsReadOnly="True" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="全選択" Command="{Binding CheckAllColumnsCommand}" />
                        <MenuItem Header="全解除" Command="{Binding UncheckAllColumnsCommand}" />
                        <MenuItem Header="テーブル定義" Command="{Binding ShowTableDefinitionFromColumnCrudCommand}" />
                        <MenuItem Header="CRUDサーチ">
                          <MenuItem Header="このカラムにアクセスしている処理" Command="{Binding CrudSearchColumnCommand}" />
                          <MenuItem Header="このテーブルにアクセスしている処理" Command="{Binding CrudSearchTableFromColumnCommand}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="コピー">
                          <MenuItem Header="選択行" Command="{Binding CopyColumnSelectedRowCommand}" />
                          <MenuItem Header="チェックを付けた行" Command="{Binding CopyColumnCheckedRowsCommand}" />
                          <MenuItem Header="全行" Command="{Binding CopyColumnAllRowsCommand}" />
                          <Separator />
                          <MenuItem Header="テーブル名" Command="{Binding CopyColumnColumnValueCommand}" CommandParameter="テーブル名" />
                          <MenuItem Header="エンティティ名" Command="{Binding CopyColumnColumnValueCommand}" CommandParameter="エンティティ名" />
                          <MenuItem Header="カラム名" Command="{Binding CopyColumnColumnValueCommand}" CommandParameter="カラム名" />
                          <MenuItem Header="属性名" Command="{Binding CopyColumnColumnValueCommand}" CommandParameter="属性名" />
                          <MenuItem Header="CRUD" Command="{Binding CopyColumnColumnValueCommand}" CommandParameter="CRUD" />
                        </MenuItem>
                        <MenuItem Header="クエリGrep">
                          <MenuItem Header="このファイルから">
                            <MenuItem Header="テーブル名" Command="{Binding GrepColumnFromFileCommand}" CommandParameter="テーブル名" />
                            <MenuItem Header="エンティティ名" Command="{Binding GrepColumnFromFileCommand}" CommandParameter="エンティティ名" />
                            <MenuItem Header="カラム名" Command="{Binding GrepColumnFromFileCommand}" CommandParameter="カラム名" />
                            <MenuItem Header="属性名" Command="{Binding GrepColumnFromFileCommand}" CommandParameter="属性名" />
                          </MenuItem>
                          <MenuItem Header="このプログラムから">
                            <MenuItem Header="テーブル名" Command="{Binding GrepColumnFromProgramCommand}" CommandParameter="テーブル名" />
                            <MenuItem Header="エンティティ名" Command="{Binding GrepColumnFromProgramCommand}" CommandParameter="エンティティ名" />
                            <MenuItem Header="カラム名" Command="{Binding GrepColumnFromProgramCommand}" CommandParameter="カラム名" />
                            <MenuItem Header="属性名" Command="{Binding GrepColumnFromProgramCommand}" CommandParameter="属性名" />
                          </MenuItem>
                          <MenuItem Header="全てのプログラムから">
                            <MenuItem Header="テーブル名" Command="{Binding GrepColumnFromAllCommand}" CommandParameter="テーブル名" />
                            <MenuItem Header="エンティティ名" Command="{Binding GrepColumnFromAllCommand}" CommandParameter="エンティティ名" />
                            <MenuItem Header="カラム名" Command="{Binding GrepColumnFromAllCommand}" CommandParameter="カラム名" />
                            <MenuItem Header="属性名" Command="{Binding GrepColumnFromAllCommand}" CommandParameter="属性名" />
                          </MenuItem>
                        </MenuItem>
                      </ContextMenu>
                    </DataGrid.ContextMenu>
                  </DataGrid>
                </Border>
              </Grid>
            </Grid>

            <GridSplitter Grid.Row="1" Background="{StaticResource AppBorderBrush}" ResizeDirection="Rows" />

            <!-- 下部: サブクエリSQLプレビュー -->
            <Border Grid.Row="2" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
              <ae:TextEditor x:Name="SqlPreview"
                             IsReadOnly="True"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="12"
                             ShowLineNumbers="True"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Auto" />
            </Border>
          </Grid>
        </TabItem>

        <!-- テーブル定義 [F2] タブ -->
        <TabItem Header="テーブル定義 [F2]">
          <Border Padding="10">
            <TextBlock Text="テーブル定義を表示するには、テーブル定義(T)ボタンを使用してください。"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="Gray" />
          </Border>
        </TabItem>

        <!-- SQL実行 [F5] タブ -->
        <TabItem Header="SQL実行 [F5]">
          <Border Padding="10">
            <TextBlock Text="SQL実行機能は準備中です。"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="Gray" />
          </Border>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
