186	DELETE FROM ORDERS WHERE ORDER_ID IN ( SELECT oh.ORDER_ID FROM ORDER_HISTORY oh WHERE oh.ARCHIVED_AT >= TRUNC ( SYSDATE ) )	SP_DATA_MIGRATION.MigrateOrderHistory
