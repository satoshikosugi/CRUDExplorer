201	SELECT c.CUSTOMER_ID, c.NAME, c.EMAIL, stats.ORDER_COUNT, stats.TOTAL_SPENT, stats.LAST_ORDER_DATE, CASE WHEN stats.TOTAL_SPENT >= ( SELECT PERCENTILE_CONT ( 0.9 ) WITHIN GROUP ( ORDER BY sub.TOTAL_SPENT ) FROM ( SELECT SUM ( o3.TOTAL_AMOUNT ) AS TOTAL_SPENT FROM ORDERS o3 WHERE o3.STATUS = 'COMPLETED' GROUP BY o3.CUSTOMER_ID ) sub ) THEN 'PLATINUM' WHEN stats.TOTAL_SPENT >= ( SELECT PERCENTILE_CONT ( 0.7 ) WITHIN GROUP ( ORDER BY sub2.TOTAL_SPENT ) FROM ( SELECT SUM ( o4.TOTAL_AMOUNT ) AS TOTAL_SPENT FROM ORDERS o4 WHERE o4.STATUS = 'COMPLETED' GROUP BY o4.CUSTOMER_ID ) sub2 ) THEN 'GOLD' WHEN stats.ORDER_COUNT >= 3 THEN 'SILVER' ELSE 'BRONZE' END AS SEGMENT FROM CUSTOMERS c JOIN ( SELECT o.CUSTOMER_ID, COUNT ( * ) AS ORDER_COUNT, SUM ( o.TOTAL_AMOUNT ) AS TOTAL_SPENT, MAX ( o.ORDER_DATE ) AS LAST_ORDER_DATE FROM ORDERS o WHERE o.STATUS = 'COMPLETED' GROUP BY o.CUSTOMER_ID ) stats ON stats.CUSTOMER_ID = c.CUSTOMER_ID ORDER BY stats.TOTAL_SPENT DESC	SP_DATA_MIGRATION.ClassifyCustomers.FOR
	SELECT c.CUSTOMER_ID , c.NAME , c.EMAIL , stats.ORDER_COUNT , stats.TOTAL_SPENT , stats.LAST_ORDER_DATE , CASE WHEN stats.TOTAL_SPENT >=  %1% THEN 'PLATINUM' WHEN stats.TOTAL_SPENT >=  %2% THEN 'GOLD' WHEN stats.ORDER_COUNT >= 3 THEN 'SILVER' ELSE 'BRONZE' END AS SEGMENT FROM CUSTOMERS c JOIN  %3% stats ON stats.CUSTOMER_ID = c.CUSTOMER_ID ORDER BY stats.TOTAL_SPENT DESC
%1%	SELECT PERCENTILE_CONT ( 0.9 ) WITHIN GROUP ( ORDER BY sub.TOTAL_SPENT ) FROM  %4% sub
%2%	SELECT PERCENTILE_CONT ( 0.7 ) WITHIN GROUP ( ORDER BY sub2.TOTAL_SPENT ) FROM  %5% sub2
%3%	SELECT o.CUSTOMER_ID , COUNT ( * ) AS ORDER_COUNT , SUM ( o.TOTAL_AMOUNT ) AS TOTAL_SPENT , MAX ( o.ORDER_DATE ) AS LAST_ORDER_DATE FROM ORDERS o WHERE o.STATUS = 'COMPLETED' GROUP BY o.CUSTOMER_ID
%4%	SELECT SUM ( o3.TOTAL_AMOUNT ) AS TOTAL_SPENT FROM ORDERS o3 WHERE o3.STATUS = 'COMPLETED' GROUP BY o3.CUSTOMER_ID
%5%	SELECT SUM ( o4.TOTAL_AMOUNT ) AS TOTAL_SPENT FROM ORDERS o4 WHERE o4.STATUS = 'COMPLETED' GROUP BY o4.CUSTOMER_ID

