<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CRUDExplorer.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="CRUDExplorer.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}"
        Width="1200" Height="800">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Background="{StaticResource AppBackgroundBrush}">

        <!-- ═══ メニューバー ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource AppPrimaryBrush}">
            <Menu Background="Transparent">
                <Menu.Styles>
                    <!-- トップレベルのメニュー項目のみ白文字（ドロップダウンは除外） -->
                    <Style Selector="Menu > MenuItem">
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                    <Style Selector="Menu > MenuItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1976D2" />
                    </Style>
                    <Style Selector="Menu > MenuItem:pointerover">
                        <Setter Property="Background" Value="#1976D2" />
                    </Style>
                </Menu.Styles>
                <MenuItem Header="開く(&amp;O)">
                    <MenuItem Header="テーブルCRUD" Command="{Binding OpenFolderCommand}" />
                    <MenuItem Header="カラムCRUD" Command="{Binding OpenFolderCommand}" />
                    <MenuItem Header="CRUDは開かない" Command="{Binding OpenFolderWithoutCrudCommand}" />
                </MenuItem>
                <MenuItem Header="CRUD解析(&amp;A)" Command="{Binding AnalyzeCrudCommand}" />
                <MenuItem Header="ソースファイル一覧(&amp;L)" Command="{Binding ShowFileListCommand}" />
                <MenuItem Header="マトリクスをクリップボードに(&amp;C)" Command="{Binding CopyMatrixToClipboardCommand}" />
                <MenuItem Header="テーブル定義参照(&amp;T)" Command="{Binding LoadTableDefCommand}" />
                <MenuItem Header="テーブル定義取込(&amp;I)" Command="{Binding ImportTableDefCommand}" />
                <MenuItem Header="クエリ解析ウィンドウ(&amp;Q)" Command="{Binding ShowQueryAnalyzerCommand}" />
                <MenuItem Header="設定(&amp;X)" Command="{Binding OpenSettingsCommand}" />
                <MenuItem Header="ヘルプ">
                    <MenuItem Header="サポートサイト" Command="{Binding OpenSupportSiteCommand}" />
                    <Separator />
                    <MenuItem Header="バージョン情報" Command="{Binding ShowVersionCommand}" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- ═══ ステータスバー ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource AppStatusBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#37474F"
                       FontSize="12"
                       VerticalAlignment="Center" />
        </Border>

        <!-- ═══ メインコンテンツ ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ツールバー -->
            <Border Grid.Row="0"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="📂 フォルダ選択"
                            Command="{Binding OpenFolderCommand}"
                            Padding="10,4" />
                    <TextBlock Text="パス:"
                               VerticalAlignment="Center"
                               Foreground="#37474F"
                               Margin="6,0,0,0" />
                    <TextBox Text="{Binding SourcePath}"
                             IsReadOnly="True"
                             MinWidth="300"
                             VerticalAlignment="Center"
                             Background="White"
                             BorderBrush="{StaticResource AppBorderBrush}" />
                    <Button Content="⚙ CRUD解析"
                            Command="{Binding AnalyzeCrudCommand}"
                            Padding="10,4" />
                    <Separator Margin="4,0" />
                    <!-- プログラムIDフィルタ -->
                    <TextBlock Text="PGフィルタ:" VerticalAlignment="Center" Foreground="#37474F" />
                    <TextBox Text="{Binding FilterProgram}"
                             Watermark="正規表現..."
                             MinWidth="120"
                             VerticalAlignment="Center"
                             Background="White" />
                    <!-- テーブルフィルタ -->
                    <TextBlock Text="テーブル:" VerticalAlignment="Center" Foreground="#37474F" />
                    <TextBox Text="{Binding FilterTable}"
                             Watermark="正規表現..."
                             MinWidth="120"
                             VerticalAlignment="Center"
                             Background="White" />
                    <!-- CRUD種別チェック -->
                    <CheckBox Content="C" IsChecked="{Binding FilterC}" VerticalAlignment="Center" />
                    <CheckBox Content="R" IsChecked="{Binding FilterR}" VerticalAlignment="Center" />
                    <CheckBox Content="U" IsChecked="{Binding FilterU}" VerticalAlignment="Center" />
                    <CheckBox Content="D" IsChecked="{Binding FilterD}" VerticalAlignment="Center" />
                    <Button Content="▶ 適用"
                            Command="{Binding ApplyFilterCommand}"
                            Padding="8,4" />
                    <Button Content="✕ クリア"
                            Command="{Binding ClearFilterCommand}"
                            Padding="8,4" />
                </StackPanel>
            </Border>

            <!-- 上下分割ペイン（オリジナル同様：上=マトリクス、下=CRUD一覧） -->
            <Grid Grid.Row="1" Margin="6,6,6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="200" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- ── CRUDマトリクス（上ペイン） ── -->
                <Border Grid.Row="0"
                        Background="{StaticResource AppPanelBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- パネルヘッダ -->
                        <Border Grid.Row="0"
                                Background="{StaticResource AppHeaderBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,6"
                                CornerRadius="4,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="CRUDマトリクス"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AppPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <ComboBox SelectedIndex="{Binding CrudViewType}" MinWidth="140">
                                    <ComboBoxItem Content="テーブルCRUD" />
                                    <ComboBoxItem Content="カラムCRUD" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid (列はMainWindow.axaml.csで動的生成) -->
                        <DataGrid Grid.Row="1"
                                  x:Name="CrudMatrixGrid"
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  BorderThickness="0"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  Background="White"
                                  RowBackground="White"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  KeyDown="OnMatrixKeyDown">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="マトリクスをクリップボードにコピー" Command="{Binding CopyMatrixToClipboardCommand}" />
                                    <MenuItem Header="テーブル定義" Click="OnContextMenuTableDef" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- グリッドスプリッター（上下） -->
                <GridSplitter Grid.Row="1"
                              Background="{StaticResource AppBorderBrush}"
                              ResizeDirection="Rows" />

                <!-- ── CRUD一覧（下ペイン） ── -->
                <Border Grid.Row="2"
                        Background="{StaticResource AppPanelBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- CRUD一覧 DataGrid（オリジナル同様の8列リスト表示） -->
                        <DataGrid Grid.Row="0"
                                  x:Name="CrudListGrid"
                                  ItemsSource="{Binding CrudListData}"
                                  SelectedItem="{Binding SelectedCrudItem}"
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  BorderThickness="0"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  Background="White"
                                  RowBackground="White"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  DoubleTapped="OnCrudListDoubleTapped"
                                  KeyDown="OnCrudListKeyDown"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="ファイル" Width="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding FileName}" VerticalAlignment="Center" Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="行番号"
                                                    Binding="{Binding LineNo}"
                                                    Width="60" />
                                <DataGridTemplateColumn Header="プログラム" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProgramId}" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding ProgramId}" VerticalAlignment="Center" Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="エンティティ名" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LogicalName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding LogicalName}" VerticalAlignment="Center" Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="テーブル名" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TableName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding TableName}" VerticalAlignment="Center" Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="CRUD"
                                                    Binding="{Binding Crud}"
                                                    Width="50" />
                                <DataGridTemplateColumn Header="関数名/カーソル名" Width="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FuncName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding FuncName}" VerticalAlignment="Center" Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="代替" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AltName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding AltName}" VerticalAlignment="Center" Margin="4,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="エディタ起動" Command="{Binding RunTextEditorCommand}" />
                                    <MenuItem Header="クエリ分析" Command="{Binding AnalyzeSelectedQueryCommand}" />
                                    <MenuItem Header="テーブル定義" Command="{Binding ShowSelectedTableDefCommand}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>

                        <!-- 下部アクションボタン -->
                        <Border Grid.Row="1"
                                Background="{StaticResource AppSurfaceBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="4,4"
                                CornerRadius="0,0,4,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="エディタ起動(_E)"
                                        Command="{Binding RunTextEditorCommand}"
                                        Padding="8,3"
                                        FontSize="11" />
                                <Button Content="クエリ分析(_A)"
                                        Command="{Binding AnalyzeSelectedQueryCommand}"
                                        Padding="8,3"
                                        FontSize="11" />
                                <Button Content="テーブル定義"
                                        Command="{Binding ShowSelectedTableDefCommand}"
                                        Padding="8,3"
                                        FontSize="11" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
